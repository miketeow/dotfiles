[
  {
    "context": "Workspace",
    "use_key_equivalents": true,
    "bindings": {
      "cmd-t": "terminal_panel::ToggleFocus",
      "cmd-b": "project_panel::ToggleFocus",
      "cmd-alt-b": "git_panel::ToggleFocus",
      "cmd-shift-b": "workspace::CloseAllDocks",
      "cmd-j": "project_symbols::Toggle",
    },
  },
  {
    "context": "ProjectPanel",
    "use_key_equivalents": true,
    "bindings": {
      "shift-cmd-n": "project_panel::NewDirectory",
      "cmd-e": "editor::ToggleFocus",
      "cmd-b": "workspace::ToggleRightDock",
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "cmd-l": "editor::DuplicateLineDown",
      "cmd-s cmd-l": "editor::SelectLine",
    },
  },
  {
    "context": "Terminal",
    "bindings": {
      "cmd-e": "editor::ToggleFocus",
      "cmd-t": "workspace::ToggleBottomDock",
    },
  },
]
